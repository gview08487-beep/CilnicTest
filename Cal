    <script>
        let rawRows = [];
        let branchRows = [];
        let doctorRows = [];
        let branchNames = [];
        let labState = {};
        let currentTab = 'doctor';
        let loadedFilesList = [];

        const money = n => Number(n || 0).toLocaleString('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        
        const num = v => {
            if (typeof v === 'number') return v;
            if (v === null || v === undefined) return 0;
            const cleaned = String(v).replace(/,/g, '').replace(/[฿\s]/g, '').trim();
            const parsed = Number(cleaned);
            return Number.isFinite(parsed) ? parsed : 0;
        };
        const clean = v => String(v ?? '').trim();

        function setStatus(msg) {
            const statusEl = document.getElementById('status');
            statusEl.style.display = 'inline-block';
            statusEl.textContent = msg;
        }

        // Modal triggers
        function openDemoModal() {
            document.getElementById('demoModal').style.display = 'flex';
        }

        function closeDemoModal() {
            document.getElementById('demoModal').style.display = 'none';
        }

        function loadDemoNote() {
            openDemoModal();
        }

        // Drag and Drop Event listeners
        const dropZone = document.getElementById('dropZone');
        
        dropZone.addEventListener('dragover', e => { 
            e.preventDefault(); 
            dropZone.classList.add('dragover');
        });
        
        dropZone.addEventListener('dragleave', () => { 
            dropZone.classList.remove('dragover');
        });
        
        dropZone.addEventListener('drop', e => {
            e.preventDefault();
            dropZone.classList.remove('dragover');
            const files = e.dataTransfer.files;
            document.getElementById('fileInput').files = files;
            
            updateFileChips(Array.from(files));
            processSelectedFiles();
        });

        // Trigger when input changes directly
        document.getElementById('fileInput').addEventListener('change', e => {
            updateFileChips(Array.from(e.target.files));
        });

        function updateFileChips(files) {
            const container = document.getElementById('uploadedFilesList');
            if (!files.length) {
                container.innerHTML = '';
                return;
            }
            container.innerHTML = files.map(file => `
                <div class="file-chip">
                    <svg viewBox="0 0 24 24"><path fill="currentColor" d="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z"/></svg>
                    <strong>${escapeHtml(file.name)}</strong>
                    <span class="file-size">(${(file.size / 1024).toFixed(1)} KB)</span>
                </div>
            `).join('');
        }

        async function processSelectedFiles() {
            const files = Array.from(document.getElementById('fileInput').files || []);
            if (!files.length) return setStatus('❌ กรุณาเลือกไฟล์ Excel ก่อน');

            rawRows = [];
            branchRows = [];
            doctorRows = [];
            branchNames = [];
            labState = {};

            setStatus('⏳ กำลังคำนวณและประมวลผลไฟล์ Excel...');

            for (const file of files) {
                try {
                    const buffer = await file.arrayBuffer();
                    const wb = XLSX.read(buffer, { type: 'array', cellDates: true });
                    const ws = wb.Sheets[wb.SheetNames[0]];
                    const rows = XLSX.utils.sheet_to_json(ws, { header: 1, defval: '' });
                    parseBranchFile(file.name, rows);
                } catch (err) {
                    console.error(err);
                    setStatus(`❌ เกิดข้อผิดพลาดในการอ่านไฟล์ ${file.name}: ${err.message}`);
                }
            }

            buildDoctorSummary();
            renderAll();
            setStatus(`✅ นำเข้าข้อมูลสำเร็จ: ประมวลผลแยกเป็น ${branchRows.length} สาขา / พบรายชื่อทันตแพทย์ทั้งหมด ${doctorRows.length} ท่าน`);
        }

        function parseBranchFile(fileName, rows) {
            const branchName = clean(rows?.[1]?.[0]) || fileName.replace(/\.xlsx?$/i, '');
            if (!branchNames.includes(branchName)) branchNames.push(branchName);

            let dentistIndex = -1;
            for (let i = 0; i < rows.length; i++) {
                if (clean(rows[i][0]).toLowerCase() === 'dentist fee') {
                    dentistIndex = i;
                    break;
                }
            }

            if (dentistIndex >= 0) {
                for (let r = dentistIndex + 2; r < rows.length; r++) {
                    const row = rows[r];
                    if (!row || row.length === 0) continue;
                    
                    const firstCell = clean(row[0]).toLowerCase();
                    if (firstCell.includes('total income summary')) break;

                    const doctor = clean(row[1]);
                    const fee = num(row[2]);
                    const df = num(row[4]);
                    const provShare = num(row[7]);

                    if (doctor && provShare) {
                        rawRows.push({
                            fileName,
                            branch: branchName,
                            doctor,
                            fee,
                            df,
                            provShare
                        });
                    }
                }
            }

            let totalIncome = 0, totalDentistFee = 0, netClinic = 0;

            let summaryIndex = -1;
            for (let i = 0; i < rows.length; i++) {
                if (clean(rows[i][0]).toLowerCase().includes('total income summary')) {
                    summaryIndex = i;
                    break;
                }
            }

            if (summaryIndex >= 0) {
                for (let r = summaryIndex + 1; r < rows.length; r++) {
                    const row = rows[r] || [];
                    const income = num(row[1]);
                    const dentistFee = num(row[2]);
                    const clinic = num(row[3]);

                    if (income || dentistFee || clinic) {
                        totalIncome = income;
                        totalDentistFee = dentistFee;
                        netClinic = clinic;
                        break;
                    }
                }
            }

            branchRows.push({
                branch: branchName,
                fileName,
                totalIncome,
                totalDentistFee,
                netClinic
            });
        }

        function buildDoctorSummary() {
            const map = new Map();
            for (const row of rawRows) {
                if (!map.has(row.doctor)) {
                    const base = { doctor: row.doctor, totalGross: 0, labCost: 0, labPercent: 100, labDeduct: 0, netPay: 0 };
                    for (const b of branchNames) base[b] = 0;
                    map.set(row.doctor, base);
                }
                const item = map.get(row.doctor);
                item[row.branch] = (item[row.branch] || 0) + row.provShare;
                item.totalGross += row.provShare;
            }
            doctorRows = Array.from(map.values()).sort((a, b) => b.totalGross - a.totalGross);
            for (const row of doctorRows) {
                labState[row.doctor] = { labCost: 0, labPercent: 100 };
                calculateLab(row.doctor);
            }
        }

        function calculateLab(doctor) {
            const row = doctorRows.find(x => x.doctor === doctor);
            if (!row) return;
            const st = labState[doctor] || { labCost: 0, labPercent: 100 };
            row.labCost = num(st.labCost);
            row.labPercent = num(st.labPercent);
            row.labDeduct = row.labCost * (row.labPercent / 100);
            row.netPay = row.totalGross - row.labDeduct;
        }

        function updateLab(doctor, field, value) {
            labState[doctor] = labState[doctor] || { labCost: 0, labPercent: 100 };
            labState[doctor][field] = value;
            calculateLab(doctor);
            renderDoctorTable();
            updateKpis();
        }

        function filteredRaw() {
            const q = clean(document.getElementById('searchInput').value).toLowerCase();
            const bf = document.getElementById('branchFilter').value;
            return rawRows.filter(r => (!q || r.doctor.toLowerCase().includes(q) || r.branch.toLowerCase().includes(q)) && (!bf || r.branch === bf));
        }

        function filteredDoctors() {
            const q = clean(document.getElementById('searchInput').value).toLowerCase();
            const bf = document.getElementById('branchFilter').value;
            return doctorRows.filter(r => {
                const hasBranch = !bf || (r[bf] || 0) !== 0;
                return (!q || r.doctor.toLowerCase().includes(q)) && hasBranch;
            });
        }

        function renderAll() {
            document.getElementById('resultPanel').style.display = 'block';
            document.getElementById('kpiCards').style.display = 'grid';

            const select = document.getElementById('branchFilter');
            select.innerHTML = '<option value="">ทุกสาขา</option>' + branchNames.map(b => `<option value="${escapeHtml(b)}">${escapeHtml(b)}</option>`).join('');

            updateKpis();
            renderCurrentTab();
        }

        function updateKpis() {
            const totalGross = doctorRows.reduce((s, r) => s + r.totalGross, 0);
            const totalNet = doctorRows.reduce((s, r) => s + r.netPay, 0);
            const totalIncome = branchRows.reduce((s, r) => s + num(r.totalIncome), 0);
            const totalDentistFee = branchRows.reduce((s, r) => s + num(r.totalDentistFee), 0);
            const totalNetClinic = branchRows.reduce((s, r) => s + num(r.netClinic), 0);
            
            document.getElementById('kpiBranches').textContent = branchRows.length;
            document.getElementById('kpiDoctors').textContent = doctorRows.length;
            document.getElementById('kpiIncome').textContent = money(totalIncome);
            document.getElementById('kpiDentistFee').textContent = money(totalDentistFee);
            document.getElementById('kpiNetClinic').textContent = money(totalNetClinic);
            document.getElementById('kpiGross').textContent = money(totalGross);
            document.getElementById('kpiNet').textContent = money(totalNet);
        }

        function showTab(tab) {
            currentTab = tab;
            document.getElementById('doctorView').style.display = tab === 'doctor' ? 'block' : 'none';
            document.getElementById('branchView').style.display = tab === 'branch' ? 'block' : 'none';
            document.getElementById('rawView').style.display = tab === 'raw' ? 'block' : 'none';
            
            document.querySelectorAll('.tab').forEach(x => x.classList.remove('active'));
            document.getElementById(tab === 'doctor' ? 'tabDoctor' : tab === 'branch' ? 'tabBranch' : 'tabRaw').classList.add('active');
            renderCurrentTab();
        }

        function renderCurrentTab() {
            if (currentTab === 'doctor') renderDoctorTable();
            if (currentTab === 'branch') renderBranchTable();
            if (currentTab === 'raw') renderRawTable();
        }

        function renderDoctorTable() {
            const table = document.getElementById('doctorTable');
            const rows = filteredDoctors();
            const branchHeaders = branchNames.map(b => `<th>${escapeHtml(b)}</th>`).join('');
            
            const totalSumByBranch = {};
            for(const b of branchNames) {
                totalSumByBranch[b] = rows.reduce((s, r) => s + (r[b] || 0), 0);
            }
            const totalGrossSum = rows.reduce((s, r) => s + r.totalGross, 0);
            const totalLabCostSum = rows.reduce((s, r) => s + r.labCost, 0);
            const totalLabDeductSum = rows.reduce((s, r) => s + r.labDeduct, 0);
            const totalNetPaySum = rows.reduce((s, r) => s + r.netPay, 0);

            table.innerHTML = `
    <thead><tr>
      <th>คุณหมอ</th>${branchHeaders}<th>รวมก่อนหักแลป</th><th>ค่าแลป</th><th>สัดส่วนหัก (%)</th><th>ค่าแลปที่หัก</th><th>ยอดจ่ายสุทธิ</th>
    </tr></thead>
    <tbody>
      ${rows.map(r => `
        <tr>
          <td>${escapeHtml(r.doctor)}</td>
          ${branchNames.map(b => `<td class="money">${money(r[b] || 0)}</td>`).join('')}
          <td class="money" style="font-weight: 700;">${money(r.totalGross)}</td>
          <td>
            <div class="input-cell-wrapper">
                <input class="input-cell" type="number" step="0.01" value="${r.labCost}" onchange="updateLab('${jsEscape(r.doctor)}','labCost',this.value)">
            </div>
          </td>
          <td>
            <div class="input-cell-wrapper">
                <input class="input-cell" type="number" step="0.1" min="0" max="100" value="${r.labPercent}" onchange="updateLab('${jsEscape(r.doctor)}','labPercent',this.value)">
            </div>
          </td>
          <td class="money"><span class="badge bad">${money(r.labDeduct)}</span></td>
          <td class="money"><span class="badge ok">${money(r.netPay)}</span></td>
        </tr>`).join('')}
        
        <!-- Total Row -->
        <tr style="background-color: var(--neutral-50); font-weight: bold;">
          <td>รวมทุกราย</td>
          ${branchNames.map(b => `<td class="money">${money(totalSumByBranch[b])}</td>`).join('')}
          <td class="money">${money(totalGrossSum)}</td>
          <td class="money">${money(totalLabCostSum)}</td>
          <td class="money">-</td>
          <td class="money"><span class="badge bad">${money(totalLabDeductSum)}</span></td>
          <td class="money"><span class="badge ok">${money(totalNetPaySum)}</span></td>
        </tr>
    </tbody>`;
        }

        function renderBranchTable() {
            const table = document.getElementById('branchTable');
            const q = clean(document.getElementById('searchInput').value).toLowerCase();
            const bf = document.getElementById('branchFilter').value;
            const rows = branchRows.filter(r => (!q || r.branch.toLowerCase().includes(q)) && (!bf || r.branch === bf));
            
            const totalIncome = rows.reduce((s, r) => s + num(r.totalIncome), 0);
            const totalDentistFee = rows.reduce((s, r) => s + num(r.totalDentistFee), 0);
            const totalNetClinic = rows.reduce((s, r) => s + num(r.netClinic), 0);
            
            table.innerHTML = `
    <thead><tr><th>ชื่อสาขา</th><th>ชื่อไฟล์ Excel</th><th>Income รวมสาขา</th><th>Dentist Fee สรุป</th><th>Net Clinic สรุป</th></tr></thead>
    <tbody>
      ${rows.map(r => `
      <tr>
        <td>${escapeHtml(r.branch)}</td>
        <td style="color: var(--neutral-600); font-size:12px;">${escapeHtml(r.fileName)}</td>
        <td class="money">${money(r.totalIncome)}</td>
        <td class="money">${money(r.totalDentistFee)}</td>
        <td class="money">${money(r.netClinic)}</td>
      </tr>
      `).join('')}
      <tr style="font-weight: 700; background: var(--neutral-50);">
        <td>รวมทั้งหมด</td>
        <td style="font-size:12px; color:var(--neutral-600)">${rows.length} สาขา</td>
        <td class="money">${money(totalIncome)}</td>
        <td class="money">${money(totalDentistFee)}</td>
        <td class="money">${money(totalNetClinic)}</td>
      </tr>
    </tbody>`;
        }

        function renderRawTable() {
            const table = document.getElementById('rawTable');
            const rows = filteredRaw();
            table.innerHTML = `
    <thead><tr><th>คุณหมอ</th><th>สาขา</th><th>ไฟล์</th><th>Fee รวม</th><th>DF สัดส่วน</th><th>Prov Share สุทธิ</th></tr></thead>
    <tbody>${rows.map(r => `
      <tr>
        <td>${escapeHtml(r.doctor)}</td>
        <td><span class="badge" style="background:#e0f2fe; color:#0369a1; font-weight:700;">${escapeHtml(r.branch)}</span></td>
        <td style="color: var(--neutral-400); font-size:12px;">${escapeHtml(r.fileName)}</td>
        <td class="money">${money(r.fee)}</td>
        <td class="money">${money(r.df)}</td>
        <td class="money" style="font-weight:700; color: var(--primary);">${money(r.provShare)}</td>
      </tr>
    `).join('')}</tbody>`;
        }

        function exportXlsx() {
            if (!doctorRows.length) return;
            const wb = XLSX.utils.book_new();
            const doctorExport = doctorRows.map(r => {
                const o = { 'คุณหมอ': r.doctor };
                for (const b of branchNames) o[b] = r[b] || 0;
                o['รวมก่อนหักแลป'] = r.totalGross;
                o['ค่าแลป'] = r.labCost;
                o['สัดส่วนหัก (%)'] = r.labPercent;
                o['ค่าแลปที่ต้องหัก'] = r.labDeduct;
                o['ยอดจ่ายสุทธิ'] = r.netPay;
                return o;
            });
            const branchExport = [...branchRows, {
                branch: 'รวมทุกสาขา',
                fileName: `${branchRows.length} สาขา`,
                totalIncome: branchRows.reduce((s, r) => s + num(r.totalIncome), 0),
                totalDentistFee: branchRows.reduce((s, r) => s + num(r.totalDentistFee), 0),
                netClinic: branchRows.reduce((s, r) => s + num(r.netClinic), 0)
            }];
            XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(doctorExport), 'รายได้คุณหมอรวม');
            XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(branchExport), 'สรุปสาขา');
            XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(rawRows), 'Raw Data');
            XLSX.writeFile(wb, 'สรุปรายได้คุณหมอ_คำนวณจากเว็บ.xlsx');
        }

        function exportCsv() {
            if (!doctorRows.length) return;
            const headers = ['คุณหมอ', ...branchNames, 'รวมก่อนหักแลป', 'ค่าแลป', 'สัดส่วนหัก (%)', 'ค่าแลปที่ต้องหัก', 'ยอดจ่ายสุทธิ'];
            const lines = [headers.join(',')];
            for (const r of doctorRows) {
                const vals = [r.doctor, ...branchNames.map(b => r[b] || 0), r.totalGross, r.labCost, r.labPercent, r.labDeduct, r.netPay];
                lines.push(vals.map(csvSafe).join(','));
            }
            const blob = new Blob(['\ufeff' + lines.join('\n')], { type: 'text/csv;charset=utf-8;' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = 'สรุปรายได้คุณหมอ.csv';
            a.click();
        }

        function clearAll() {
            rawRows = []; branchRows = []; doctorRows = []; branchNames = []; labState = {};
            document.getElementById('fileInput').value = '';
            document.getElementById('resultPanel').style.display = 'none';
            document.getElementById('kpiCards').style.display = 'none';
            updateFileChips([]);
            setStatus('🧹 ล้างข้อมูลเรียบร้อยแล้ว');
            
            setTimeout(() => {
                const st = document.getElementById('status');
                st.style.display = 'none';
            }, 3000);
        }

        function escapeHtml(str) {
            return String(str ?? '').replace(/[&<>"]/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[m]));
        }
        function jsEscape(str) { return String(str ?? '').replace(/\\/g, '\\\\').replace(/'/g, "\\'"); }
        
        function csvSafe(v) {
            const s = String(v ?? '');
            return /[",\n]/.test(s) ? '"' + s.replace(/"/g, '""') + '"' : s;
        }
    </script>
</body>

